<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:startDestination="@id/loginFragment">

    <fragment android:id="@+id/loginFragment"
        android:name="com.example.bankapplication.fragments.LoginFragment">
        <action android:id="@+id/toRegister"
            app:destination="@id/registerFragment"/>
        <action android:id="@+id/toHome"
            app:destination="@id/homeFragment"/>
    </fragment>

    <fragment android:id="@+id/registerFragment"
        android:name="com.example.bankapplication.fragments.RegisterFragment">
        <action android:id="@+id/toLogin"
            app:destination="@id/loginFragment"/>
    </fragment>

    <fragment android:id="@+id/homeFragment"
        android:name="com.example.bankapplication.fragments.HomeFragment">
        <action android:id="@+id/toTransfer"
            app:destination="@id/transferFragment"/>
        <action android:id="@+id/toAdmin"
            app:destination="@id/adminFragment"/>
    </fragment>

    <fragment android:id="@+id/transferFragment"
        android:name="com.example.bankapplication.fragments.TransferFragment"/>

    <fragment android:id="@+id/adminFragment"
        android:name="com.example.bankapplication.fragments.AdminFragment"/>
</navigation>